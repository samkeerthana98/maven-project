# =============================================================================
# .dockerignore
# -----------------------------------------------------------------------------
# Files and directories listed here are excluded from the Docker build context.
# A smaller build context means:
#   - Faster `docker build` (less data sent to the Docker daemon).
#   - No risk of accidentally baking secrets or local configs into the image.
# =============================================================================

# -----------------------------------------------------------------------------
# Maven build output
# These are generated by `mvn package` locally and must not be sent to Docker.
# The builder stage inside the Dockerfile compiles from scratch, so local
# target/ directories would only bloat the context and could cause conflicts.
# -----------------------------------------------------------------------------
**/target/

# -----------------------------------------------------------------------------
# Version control
# Git history and metadata are irrelevant inside a container image.
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# IDE and editor configuration
# These are developer tooling files and have no place in a Docker image.
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-generated junk
# Thumbnail caches and DS_Store files generated by macOS/Windows.
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# Any log files present locally should not end up in the image.
# -----------------------------------------------------------------------------
logs/
*.log
log/

# -----------------------------------------------------------------------------
# Node.js (not used in this project, but guards against future additions)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log

# -----------------------------------------------------------------------------
# Docker files themselves
# The Dockerfile and .dockerignore don't need to be in the image filesystem.
# -----------------------------------------------------------------------------
Dockerfile
.dockerignore

# -----------------------------------------------------------------------------
# CI / pipeline files
# Jenkins and other CI config are build orchestration, not application code.
# -----------------------------------------------------------------------------
Jenkinsfile
script.groovy

# -----------------------------------------------------------------------------
# Test and documentation artifacts
# -----------------------------------------------------------------------------
**/src/site/
test.txt

# -----------------------------------------------------------------------------
# Environment / secrets
# Prevent accidental inclusion of credentials or local overrides.
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.p12
*.jks
